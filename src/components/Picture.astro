---
import { Picture as AstroPicture } from "astro:assets";
import { renderPDF } from "../lib/render-pdf";

interface Props {
  src: ImageMetadata | `${string}.pdf`;
  alt: string;
  priority?: boolean;
  invertInDarkMode?: boolean;
  maxWidth?: string;
}

const {
  src,
  alt,
  priority = false,
  invertInDarkMode = false,
  maxWidth,
} = Astro.props;

let image: ImageMetadata;

if (typeof src === "string") {
  image = await renderPDF(src);
} else {
  image = src;
}
---

<AstroPicture
  class={`rounded-lg max-h-[calc(100svh-3rem)] max-w-full w-min mx-auto ${invertInDarkMode ? "dark:invert" : ""}`}
  style={maxWidth ? `width: 100%; max-width: ${maxWidth};` : undefined}
  src={image}
  alt={alt}
  layout="constrained"
  formats={["avif"]}
  priority={priority}
  fit="contain"
/>
