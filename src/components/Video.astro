---
import type { HTMLAttributes } from "astro/types";
interface Props extends HTMLAttributes<"video"> {
  src: string;
  playWhenVisible?: boolean;
  cropEdges?: boolean;
  compact?: boolean;
  maxWidth?: string;
  cropScale?: number;
}

const {
  src,
  playWhenVisible = false,
  cropEdges = false,
  compact = false,
  maxWidth,
  cropScale,
  controls = true,
  loop = true,
  playsinline = true,
  muted = true,
  autoplay = true,
  style,
  ...videoProps
} = Astro.props;

const resolvedMaxWidth = maxWidth ?? (compact ? "42rem" : undefined);
const resolvedCropScale = cropScale ?? (cropEdges ? 1.03 : 1);

const wrapperClass = `overflow-hidden rounded-lg bg-transparent shadow-none ${
  resolvedMaxWidth ? "mx-auto" : ""
}`;
const wrapperStyle = resolvedMaxWidth ? `max-width: ${resolvedMaxWidth};` : undefined;

const videoClass = "block h-auto w-full bg-transparent shadow-none";
const videoStyle = [
  style,
  resolvedCropScale !== 1
    ? `transform: scale(${resolvedCropScale}); transform-origin: center;`
    : undefined,
]
  .filter(Boolean)
  .join(" ");
---

<div class={wrapperClass} style={wrapperStyle}>
  <video
    class={videoClass}
    style={videoStyle}
    src={src}
    controls={controls}
    loop={loop}
    playsinline={playsinline}
    muted={muted}
    autoplay={playWhenVisible ? false : autoplay}
    data-play-when-visible={playWhenVisible ? "true" : undefined}
    {...videoProps}></video>
</div>

<script>
  const videos = document.querySelectorAll<HTMLVideoElement>(
    "video[data-play-when-visible='true']",
  );

  if ("IntersectionObserver" in window) {
    const observer = new IntersectionObserver(
      (entries) => {
        for (const entry of entries) {
          const video = entry.target as HTMLVideoElement;

          if (entry.isIntersecting) {
            video.play().catch(() => {});
            observer.unobserve(video);
          }
        }
      },
      { threshold: 0.35 },
    );

    videos.forEach((video) => observer.observe(video));
  } else {
    videos.forEach((video) => video.play().catch(() => {}));
  }
</script>
